# Anonymization Test Automation - Environment Variables Template
#
# SETUP INSTRUCTIONS:
# 1. Copy this file and rename it to ".env"
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit the .env file to Git
#
# ⚠️  This is a TEMPLATE file - it does NOT contain real credentials

# ============================================================================
# UI Test Credentials (for Playwright tests)
# ============================================================================
APP_USERNAME=your_username_here
APP_PASSWORD=your_password_here

# ============================================================================
# API Credentials (for role update scripts)
# Used by: api_role_updater.py, api_role_updater_approver.py
# ============================================================================
API_USERNAME=your_api_username_here
API_PASSWORD=your_api_password_here

# ============================================================================
# User Profile Data (for API role updates)
# ============================================================================
USER_ID=0
USER_FIRSTNAME=YourFirstName
USER_LASTNAME=YourLastName
USER_EMAIL=your.email@company.com
USER_LOCATION=OnShore

# Role IDs (reference - do not change unless roles change in system)
REDACTOR_ROLE_ID=2
APPROVER_ROLE_ID=3

# ============================================================================
# Environment Configuration
# ============================================================================
# Set to "true" for headless browser mode (useful for CI/CD)
HEADLESS=false
